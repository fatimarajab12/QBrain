@startuml
title Activity Diagram - Section Matching Analysis

skinparam defaultFontSize 11
skinparam activity {
    BackgroundColor CornflowerBlue
    BorderColor #0066CC
}

|User|
start
:Request section analysis\n(Section1Query + Section2Query\n+ Project ID);

|System|
:Receive section matching request;

fork
    :Get Section 1 context\n(Similarity search from Supabase);
    note right: Retrieving section 1
fork again
    :Get Section 2 context\n(Similarity search from Supabase);
    note right: Retrieving section 2
end fork

:Combine both contexts\n(Format with section markers);

:Build analysis prompt\n(Match types, Scores, Section references,\nAnalysis structure);
note right: Comprehensive analysis prompt

:Invoke OpenAI GPT-4o\n(Analysis model, temperature: 0.3);
note right: Deep analysis processing...

:Generate comprehensive analysis\n(matchScore, strengths,\nimprovements, conclusion,\nintegration plan);

:Parse JSON analysis;

:Enhance result\n(Add metadata: timestamps, chunk counts);

:Return analysis result;

|User|
:Receive analysis report\n(directAnswer, overallMatchScore,\nfunctionalMatch, strengths,\nimprovements, conclusion);
:Review matching analysis;
:Use recommendations for improvement;
stop

@enduml
