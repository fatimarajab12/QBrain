@startuml Failure Points
!theme cerulean
skinparam activity {
    BackgroundColor #FFEBEE
    BorderColor #C62828
    FontSize 12
}

skinparam arrow {
    Color #C62828
}

title Failure Points

start

partition "File Upload" {
    :Missing Config;
    :Invalid File Type;
    :Empty Text;
}

partition "Feature Extraction" {
    :SRS Not Uploaded;
    :No Context;
    :Invalid JSON;
}

partition "Test Cases" {
    :Feature Not Found;
    :Context Failed;
    :Parse Error;
}

partition "Chatbot" {
    :No Vector Data;
    :Query Failed;
}

stop

@enduml
