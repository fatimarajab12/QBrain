@startuml
title UI Screens - Detailed Frontend Components

skinparam componentStyle rectangle
skinparam shadowing false
skinparam linetype ortho
skinparam defaultFontSize 10

' ===== SCREEN 1: DASHBOARD =====
rectangle "Dashboard Screen" #LightBlue {
  [Header: "Projects" + Create Button] as DashboardHeader
  [Empty State\nOR\nProjects Grid\n(3 columns)] as DashboardContent
  component "Project Card Shows:\n- Project Name\n- Description\n- SRS Status\n- Features Count\n- Test Cases Count\n- Delete Button" as ProjectCardDetails
}

' ===== SCREEN 2: PROJECT DETAILS =====
rectangle "Project Details Screen" #LightGreen {
  [Header: Back Button + Project Name] as ProjectHeader
  
  rectangle "SRS Section" #LightGray {
    [Upload SRS Button\n(Shows current file if uploaded)] as SRSButton
    component "Status: Uploaded/Not Uploaded" as SRSStatus
  }
  
  rectangle "Tabs Section" #LightGray {
    [Features Tab] as FeaturesTab
    [Bugs Tab] as BugsTab
  }
  
  rectangle "Features Tab Content" #LightCyan {
    [Search Bar] as SearchBar
    [Filter: Status + Priority] as Filters
    [Sort Dropdown] as Sort
    [Generate with AI Button] as AIGenerateBtn
    [Create Feature Button] as CreateFeatureBtn
    [Features Grid\n(Feature Cards)] as FeaturesGrid
  }
}

' ===== SCREEN 3: FEATURE DETAILS =====
rectangle "Feature Details Screen" #Moccasin {
  [Header: Back Button + Feature Name] as FeatureHeader
  
  rectangle "Feature Info Section" #LightGray {
    component "Feature Info Card:\n- Name\n- Description\n- Priority (High/Medium/Low)\n- Status\n- Feature Type\n- Acceptance Criteria\n- AI Reasoning\n- Matched SRS Sections" as FeatureInfoCard
  }
  
  rectangle "Stats Section" #LightGray {
    component "Stats Grid:\n- Total Test Cases\n- Passed Test Cases\n- Failed Test Cases\n- Total Bugs\n- Coverage %" as StatsSection
  }
  
  rectangle "Tabs Section" #LightGray {
    [Test Cases Tab] as TestCasesTab
    [Bugs Tab] as BugsTab2
  }
  
  rectangle "Test Cases Tab Content" #LightGreen {
    [Search + Filters] as TCFilters
    [Generate with AI Button] as AITestCaseBtn
    [Create Test Case Button] as CreateTCBtn
    [Test Cases List\n(Test Case Cards)] as TestCasesList
    component "Test Case Card Shows:\n- Title\n- Description\n- Priority\n- Status\n- Steps\n- Expected Result\n- Edit/Delete Buttons" as TCCardDetails
  }
}

' ===== DIALOGS =====
rectangle "Dialogs" #Pink {
  [Upload SRS Dialog\n- File upload area\n- Drag & drop\n- File validation\n- Upload button] as UploadDialog
  
  [AI Generation Dialog\n- Options (comprehensive mode)\n- Generate button\n- Progress indicator\n- Review generated features] as AIGenerateDialog
  
  [Create Feature Dialog\n- Name input\n- Description textarea\n- Priority dropdown\n- Feature type dropdown\n- Acceptance criteria\n- Create button] as CreateFeatureDialog
  
  [AI Test Case Generation Dialog\n- Options\n- Generate button\n- Progress indicator] as AITestCaseDialog
  
  [Create Test Case Dialog\n- Title input\n- Description textarea\n- Steps (list)\n- Expected result\n- Priority dropdown\n- Preconditions\n- Create button] as CreateTCDialog
  
  [Edit Test Case Dialog\n- Same as Create\n- Pre-filled with data\n- Update button] as EditTCDialog
}

' ===== CHATBOT =====
rectangle "Chatbot Widget" #Yellow {
  [Chatbot Sidebar\n(Expandable)] as ChatbotWidget
  component "Chat Interface:\n- Chat messages list\n- User questions\n- AI answers (with citations)\n- Input field\n- Send button\n- Loading indicator" as ChatInterface
}

' ===== NOTIFICATIONS =====
rectangle "Notifications" #Wheat {
  [Toast Notifications\n- Success messages\n- Error messages\n- Info messages\n- Loading states] as Toasts
}

' ===== NAVIGATION =====
DashboardContent --> ProjectHeader : Click project card
ProjectHeader --> SRSButton : View project
SRSButton --> UploadDialog : Click upload
UploadDialog --> SRSStatus : Upload success

FeaturesTab --> SearchBar : View features
AIGenerateBtn --> AIGenerateDialog : Click generate
AIGenerateDialog --> FeaturesGrid : Features generated

CreateFeatureBtn --> CreateFeatureDialog : Click create
CreateFeatureDialog --> FeaturesGrid : Feature created

FeaturesGrid --> FeatureHeader : Click feature card

FeatureHeader --> FeatureInfoCard : View feature
TestCasesTab --> TCFilters : View test cases

AITestCaseBtn --> AITestCaseDialog : Click generate
AITestCaseDialog --> TestCasesList : Test cases generated

CreateTCBtn --> CreateTCDialog : Click create
CreateTCDialog --> TestCasesList : Test case created

TestCasesList --> EditTCDialog : Click edit
EditTCDialog --> TestCasesList : Test case updated

ChatbotWidget --> ChatInterface : Open chatbot
ChatInterface --> Toasts : Show notifications

legend right
  |<#LightBlue> **Dashboard** | Main projects view |
  |<#LightGreen> **Project** | Project features |
  |<#Moccasin> **Feature** | Feature details |
  |<#Pink> **Dialogs** | Modal windows |
  |<#Yellow> **Chatbot** | AI assistant |
  |<#Wheat> **Feedback** | User notifications |
endlegend

@enduml

