@startuml RAG Query Flow
skinparam defaultFontName "Arial"
skinparam defaultFontSize 14
skinparam defaultFontColor #0F2F6B
skinparam roundcorner 10
skinparam shadowing false
skinparam Padding 12
skinparam nodesep 40
skinparam ranksep 30
skinparam ArrowColor #1976D2
skinparam ArrowThickness 2
skinparam ArrowFontSize 13
skinparam ArrowFontName "Arial"

skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontColor #0F2F6B
    FontStyle bold
}

skinparam database {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontColor #0F2F6B
    FontStyle bold
}

title <b>RAG Query Flow</b>\nAdvanced RAG Process

left to right direction

actor      "User" as User
component  "Retrieval\nModel\nSimilarity Search" as Retrieval #E3F2FD
component  "Embedding\nModel\ntext-embedding-3-small" as Embed #E3F2FD
database   "Knowledge\nBase\nVector Store" as KB #E3F2FD
component  "Language\nModel\nGPT-4o-mini" as LLM #E3F2FD
actor      "Response" as Resp

User --> Retrieval : 1. Query
Embed --> Retrieval : 2. Encode
Retrieval --> KB : 3. Search KB
KB --> Retrieval : 4. Retrieved Context
Retrieval --> LLM : 5. Rank / Compose
LLM --> Resp : 6. Response

@enduml
