@startuml
title UI Flow - Frontend User Interface

skinparam componentStyle rectangle
skinparam shadowing false
skinparam linetype ortho
skinparam defaultFontSize 11

' ===== AUTHENTICATION =====
rectangle "Authentication" #LightGray {
  [Login Page\n(/login)] as LoginPage #LightBlue
  note right of LoginPage
    - Email & Password form
    - Login button
    - Redirect to Dashboard
  end note
}

' ===== MAIN LAYOUT =====
rectangle "Main Layout" #LightGray {
  [App Layout\n(Sidebar + Header)] as AppLayout #Gold
  component "Sidebar\n(Projects Link)" as Sidebar
  component "Header\n(User Menu)" as Header
}

' ===== DASHBOARD =====
rectangle "Dashboard\n(/dashboard)" #LightGray {
  [Projects List View] as Dashboard #LightBlue
  component "Projects Grid\n(Project Cards)" as ProjectsGrid
  component "Create Project Dialog" as CreateProjectDialog
  component "Project Card\n(Preview)" as ProjectCard
}

' ===== PROJECT DETAILS =====
rectangle "Project Details\n(/projects/:projectId)" #LightGray {
  [Project Page] as ProjectPage #LightBlue
  component "Project Header\n(Back Button + Title)" as ProjectHeader
  component "Upload SRS Dialog" as UploadSRSDialog
  component "Gooey Tabs\n(Features / Bugs)" as Tabs
}

rectangle "Features Tab" #LightGray {
  [Features List View] as FeaturesView #LightGreen
  component "Search Bar" as SearchBar
  component "Filters\n(Status, Priority)" as Filters
  component "Sort Options" as SortOptions
  component "AI Generation Dialog" as AIGenerationDialog
  component "Create Feature Dialog" as CreateFeatureDialog
  component "Feature Cards Grid" as FeatureCards
  component "Feature Card\n(Name, Priority, Status,\nTest Cases Count)" as FeatureCardItem
}

rectangle "Bugs Tab" #LightGray {
  [Bugs List View] as BugsView #Pink
  component "Bugs Table" as BugsTable
  component "Add Bug Dialog" as AddBugDialog
}

' ===== FEATURE DETAILS =====
rectangle "Feature Details\n(/projects/:projectId/features/:featureId)" #LightGray {
  [Feature Detail Page] as FeatureDetailPage #LightBlue
  component "Feature Header\n(Back Button + Title)" as FeatureHeader
  component "Feature Info Card\n(Name, Description, Priority,\nReasoning, Matched Sections)" as FeatureInfo
  component "Stats Grid\n(Test Cases, Bugs, Coverage)" as StatsGrid
  component "Tabs\n(Test Cases / Bugs)" as FeatureTabs
}

rectangle "Test Cases Tab" #LightGray {
  [Test Cases List] as TestCasesView #LightGreen
  component "Search & Filters" as TestCaseFilters
  component "AI Test Case Generation\nDialog" as AITestCaseDialog
  component "Create Test Case Dialog" as CreateTestCaseDialog
  component "Edit Test Case Dialog" as EditTestCaseDialog
  component "Test Case Cards\n(Status, Priority, Steps)" as TestCaseCards
}

rectangle "Bugs Tab (Feature)" #LightGray {
  [Feature Bugs List] as FeatureBugsView #Pink
  component "Feature Bugs Table" as FeatureBugsTable
}

' ===== CHATBOT =====
rectangle "Chatbot" #LightGray {
  [Project Chatbot\n(Sidebar Widget)] as Chatbot #LightCyan
  component "Chat Interface" as ChatInterface
  component "Message Input" as MessageInput
  component "Chat Messages\n(Questions + AI Answers)" as ChatMessages
}

' ===== NAVIGATION FLOW =====
LoginPage --> AppLayout : Login Success
AppLayout --> Sidebar
AppLayout --> Header

Sidebar --> Dashboard : Click "Projects"

Dashboard --> ProjectsGrid : Show projects
Dashboard --> CreateProjectDialog : "Create Project" button
CreateProjectDialog --> Dashboard : Project created
ProjectsGrid --> ProjectCard : Display each project
ProjectCard --> ProjectPage : Click project

ProjectPage --> ProjectHeader : Display header
ProjectPage --> UploadSRSDialog : "Upload SRS" button
UploadSRSDialog --> ProjectPage : SRS uploaded\n(Success toast)

ProjectPage --> Tabs : Toggle tabs
Tabs --> FeaturesView : "Features" tab
Tabs --> BugsView : "Bugs" tab

FeaturesView --> SearchBar : Search features
FeaturesView --> Filters : Filter by status/priority
FeaturesView --> SortOptions : Sort features
FeaturesView --> AIGenerationDialog : "Generate with AI" button
AIGenerationDialog --> FeaturesView : Features generated\n(Progress + Success toast)
FeaturesView --> CreateFeatureDialog : "Create Feature" button
CreateFeatureDialog --> FeaturesView : Feature created

FeaturesView --> FeatureCards : Display features
FeatureCards --> FeatureCardItem : Each feature card
FeatureCardItem --> FeatureDetailPage : Click feature

FeatureDetailPage --> FeatureHeader : Display header
FeatureDetailPage --> FeatureInfo : Display feature info
FeatureDetailPage --> StatsGrid : Display statistics
FeatureDetailPage --> FeatureTabs : Toggle tabs

FeatureTabs --> TestCasesView : "Test Cases" tab
FeatureTabs --> FeatureBugsView : "Bugs" tab

TestCasesView --> TestCaseFilters : Search & filter
TestCasesView --> AITestCaseDialog : "Generate with AI" button
AITestCaseDialog --> TestCasesView : Test cases generated\n(Progress + Success toast)
TestCasesView --> CreateTestCaseDialog : "Create Test Case" button
CreateTestCaseDialog --> TestCasesView : Test case created

TestCasesView --> TestCaseCards : Display test cases
TestCaseCards --> EditTestCaseDialog : Click edit
EditTestCaseDialog --> TestCasesView : Test case updated

' ===== CHATBOT INTEGRATION =====
AppLayout --> Chatbot : Available in sidebar
ProjectPage --> Chatbot : Open chatbot
Chatbot --> ChatInterface : Display chat
ChatInterface --> MessageInput : User types question
MessageInput --> ChatInterface : Send question
ChatInterface --> ChatMessages : Display AI answer

' ===== USER ACTIONS FLOW =====
note right of UploadSRSDialog
  **Upload SRS:**
  1. Click "Upload SRS" button
  2. Select PDF/TXT file
  3. File validation (size, type)
  4. Upload progress
  5. Success toast
  6. SRS status updated
end note

note right of AIGenerationDialog
  **Generate Features:**
  1. Click "Generate with AI"
  2. Select options (comprehensive mode)
  3. Loading progress
  4. Features generated
  5. Review & approve dialog
  6. Success toast
end note

note right of AITestCaseDialog
  **Generate Test Cases:**
  1. Click "Generate with AI"
  2. Select options
  3. Loading progress
  4. Test cases generated
  5. Success toast
end note

note right of ChatInterface
  **Chatbot:**
  1. Type question
  2. Click send
  3. Loading indicator
  4. AI answer displayed
  5. Can ask follow-up questions
end note

legend right
  |<#LightBlue> **Pages** | Main screens |
  |<#Gold> **Layout** | App structure |
  |<#LightGreen> **Features** | Feature management |
  |<#Pink> **Bugs** | Bug tracking |
  |<#LightCyan> **Chatbot** | AI assistant |
endlegend

@enduml

