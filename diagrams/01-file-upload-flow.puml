@startuml File Upload Flow
skinparam defaultFontName "Arial"
skinparam defaultFontSize 14
skinparam defaultFontColor #0F2F6B
skinparam roundcorner 10
skinparam shadowing false
skinparam Padding 12
skinparam nodesep 40
skinparam ranksep 30
skinparam ArrowColor #1976D2
skinparam ArrowThickness 2
skinparam ArrowFontSize 13
skinparam ArrowFontName "Arial"

skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontColor #0F2F6B
    FontStyle bold
}

skinparam database {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontColor #0F2F6B
    FontStyle bold
}

title <b>File Upload Flow</b>\nSRS Document Processing Pipeline

left to right direction

actor "User\nUpload SRS" as User
component "SRS Document\n(PDF/TXT)\nFile Upload" as Doc #E3F2FD
component "Document AI\nExtract Text\nTables & Forms\nOCR Support" as Extract #E3F2FD
component "Text Splitter\nRecursiveCharacter\n2000 chars\n300 overlap" as Split #E3F2FD
component "Text Chunks\nSegments\nReady for Embedding" as Chunks #E3F2FD
component "Embedding Model\ntext-embedding-3-small\n1536 dimensions\nBatch Processing" as Embed #E3F2FD
database  "Vector Store\nSupabase pgvector\nStore Embeddings" as Vector #E3F2FD
database  "MongoDB\nUpdate Project\nprocessed: true\nchunksCount" as Mongo #E3F2FD

User   --> Doc    : 1. Upload
Doc    --> Extract: 2. File
Extract--> Split  : 3. Extracted Text
Split  --> Chunks : 4. Split
Chunks --> Embed  : 5. Encode
Embed  --> Vector : 6. Store
Vector --> Mongo  : 7. Update

@enduml
