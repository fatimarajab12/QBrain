@startuml Test Case Generation Flow
skinparam defaultFontName "Arial"
skinparam defaultFontSize 14
skinparam defaultFontColor #0F2F6B
skinparam roundcorner 10
skinparam shadowing false
skinparam Padding 12
skinparam nodesep 40
skinparam ranksep 30
skinparam ArrowColor #1976D2
skinparam ArrowThickness 2
skinparam ArrowFontSize 13
skinparam ArrowFontName "Arial"

skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontColor #0F2F6B
    FontStyle bold
}

skinparam database {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontColor #0F2F6B
    FontStyle bold
}

title <b>Test Case Generation Flow</b>\nSimple RAG Process for Test Cases

left to right direction

actor      "Feature\nSelected\nType & Sections" as Feature
database   "Vector Store\nSupabase pgvector\nSRS Chunks" as VecSrc #E3F2FD
component  "Embedding Model\ntext-embedding-3-small\nQuery Embedding" as Embed #E3F2FD
component  "Search Sections\nFrom Matched Sections\nSimilarity Search" as SearchSections #E3F2FD
component  "Search General\nContext Chunks\nTop-K Results" as SearchGeneral #E3F2FD
component  "Context\nSection + General\nChunks Combined" as Context #E3F2FD
component  "LLM\nGPT-4o-mini\nGenerate Test Cases\nJSON Mode" as LLM #E3F2FD
component  "Parse & Validate\nConvert to Gherkin\nFormat" as Parse #E3F2FD
database   "MongoDB\nSave Test Cases\nwith Gherkin" as Mongo #E3F2FD
database   "Vector Store\nAdd Test Cases\nto Embeddings" as VecOut #E3F2FD

Feature  --> Embed           : 1. Feature Data
VecSrc   --> SearchSections  : 2. SRS Chunks
VecSrc   --> SearchGeneral   : 3. SRS Chunks
Embed    --> SearchSections  : 4. Query Embedding
Embed    --> SearchGeneral   : 5. Query Embedding
SearchSections --> Context   : 6. Section Context
SearchGeneral  --> Context   : 7. General Context
Context  --> LLM             : 8. Combined Context
Feature  --> LLM             : 9. Feature Info
LLM      --> Parse           : 10. Test Cases JSON
Parse    --> Mongo           : 11. Save
Parse    --> VecOut          : 12. Add to Vector

@enduml
