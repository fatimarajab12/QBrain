@startuml Feature Extraction Flow
skinparam defaultFontName "Arial"
skinparam defaultFontSize 14
skinparam defaultFontColor #0F2F6B
skinparam roundcorner 10
skinparam shadowing false
skinparam Padding 12
skinparam nodesep 40
skinparam ranksep 30
skinparam ArrowColor #1976D2
skinparam ArrowThickness 2
skinparam ArrowFontSize 13
skinparam ArrowFontName "Arial"

skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontColor #0F2F6B
    FontStyle bold
}

skinparam database {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontColor #0F2F6B
    FontStyle bold
}

title <b>Feature Extraction Flow</b>\nSimple RAG Process

left to right direction

actor      "User\nExtract Features\nfrom SRS" as User
database   "Vector Store\nSupabase pgvector\nSRS Chunks" as VecSrc #E3F2FD
component  "Embedding Model\ntext-embedding-3-small\nQuery Embedding" as Embed #E3F2FD
component  "Similarity Search\nRetrieve Top-K\nRelevant Chunks\nCosine Distance" as Search #E3F2FD
component  "Re-rank / Filter\nTop Ranked Chunks" as Rerank #E3F2FD
component  "Group Chunks\nby Sections\nCoverage Analysis" as Grouped #E3F2FD
component  "LLM\nGPT-4o-mini\nExtract Features\nJSON Response" as LLM #E3F2FD
database   "MongoDB\nSave Features\nwith Metadata" as Mongo #E3F2FD
database   "Vector Store\nAdd Features\nto Embeddings" as VecOut #E3F2FD

User  --> Embed   : 1. Request
VecSrc --> Search : 2. Chunks
Embed --> Search  : 3. Query Embedding
Search --> Rerank : 4. Relevant Chunks
Rerank --> Grouped: 5. Filtered / Ranked
Grouped --> LLM   : 6. Grouped Context
User --> LLM      : 7. Original Query
LLM --> Mongo     : 8. Features JSON
LLM --> VecOut    : 9. Add to Vector

@enduml
