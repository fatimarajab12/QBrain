# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment — ignore all .env files (root + subfolders; Git does not treat .env* as matching paths like backend/.env)
**/.env
**/.env.*
.env
.env.*

# Keys / certs (often referenced from .env paths)
*.pem
*.p12
**/gcp-key.json

# Backend user uploads (generated at runtime)
backend/uploads/

# Test / coverage
coverage/
*.lcov
.nyc_output/

# Python (rag_lab and any tooling)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/

# TypeScript incremental
*.tsbuildinfo

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Python RAG lab (venv; .env patterns above)
rag_lab/.venv/
